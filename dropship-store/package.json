{
  "name": "dropship-store",
  "version": "1.0.0",
  "description": "Self-hosted dropshipping storefront + admin panel, targeted at the US market.",
  "main": "server.js",
  "type": "commonjs",
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "start": "node --no-warnings server.js",

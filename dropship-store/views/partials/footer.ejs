  </main>

  <footer class="site-footer">
    <div class="wrap footer-grid">
      <div class="footer-brand">
        <div class="brand"><span class="brand-mark">🛍️</span> <span class="brand-name"><%= storeName %></span></div>
        <p><%= store.store_tagline %></p>
        <p class="ship-note">🇺🇸 Fast shipping across the United States · Ships in 1–2 business days</p>
      </div>
      <div class="footer-col">
        <h4>Shop</h4>
        <a href="/shop">All Products</a>
        <% navCategories.forEach(function(c){ %><a href="/shop?category=<%= encodeURIComponent(c) %>"><%= c %></a><% }); %>
      </div>
      <div class="footer-col">
        <h4>Help</h4>
        <a href="/cart">Your Cart</a>
        <a href="mailto:<%= store.support_email %>">Contact Support</a>
        <a href="/admin">Store Admin</a>
      </div>
      <div class="footer-col">
        <h4>Why <%= storeName %>?</h4>
        <p class="trust">✓ Secure checkout<br>✓ 30-day money-back guarantee<br>✓ US-based support</p>
      </div>
    </div>
    <div class="wrap footer-bottom">
      <span>© <%= year %> <%= storeName %>. All rights reserved.</span>
      <span>Payments processed securely · USD</span>
    </div>
  </footer>

  <script src="/js/main.js" defer></script>
</body>
</html>

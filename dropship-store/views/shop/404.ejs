<%- include('../partials/header') %>

<div class="empty tall">
  <p class="empty-emoji"><%= typeof serverError !== 'undefined' && serverError ? '⚠️' : '🧭' %></p>
  <h1><%= typeof serverError !== 'undefined' && serverError ? 'Something went wrong' : 'Page not found' %></h1>
  <p class="muted">
    <% if (typeof serverError !== 'undefined' && serverError) { %>
      We hit an unexpected error. Please try again in a moment.
    <% } else { %>
      The page you're looking for doesn't exist or may have moved.
    <% } %>
  </p>
  <a href="/" class="btn btn-primary">Back to home</a>
</div>

<%- include('../partials/footer') %>

<%- include('../partials/header') %>

<h1 class="page-title">Your Cart</h1>

<% if (items.length === 0) { %>
  <div class="empty">
    <p class="empty-emoji">🛒</p>
    <h2>Your cart is empty</h2>
    <p class="muted">Add some trending products to get started.</p>
    <a href="/shop" class="btn btn-primary">Start shopping</a>
  </div>
<% } else { %>
  <div class="cart-layout">
    <form class="cart-items" action="/cart/update" method="post">
      <% items.forEach(function(it){ %>
        <div class="cart-row">
          <a href="/product/<%= it.product.slug %>" class="cart-thumb">
            <img src="/img/product/<%= it.product.slug %>.svg" alt="<%= it.product.title %>" width="80" height="80" />
          </a>
          <div class="cart-info">
            <a href="/product/<%= it.product.slug %>" class="cart-name"><%= it.product.title %></a>
            <span class="muted"><%= it.product.category %></span>
            <span class="cart-unit"><%= money(it.product.price_cents) %> each</span>
          </div>
          <div class="cart-qty">
            <input type="number" name="qty_<%= it.product.id %>" value="<%= it.quantity %>" min="0" max="99" aria-label="Quantity" />
          </div>
          <div class="cart-line"><%= money(it.lineTotalCents) %></div>
        </div>
      <% }); %>
      <div class="cart-actions">
        <a href="/shop" class="btn btn-ghost">← Continue shopping</a>
        <button type="submit" class="btn btn-secondary">Update cart</button>
      </div>
    </form>

    <aside class="cart-summary">
      <h2>Order summary</h2>
      <div class="sum-row"><span>Subtotal</span><span><%= money(totals.subtotalCents) %></span></div>
      <div class="sum-row">
        <span>Shipping</span>
        <span><%= totals.shippingCents === 0 ? 'FREE' : money(totals.shippingCents) %></span>
      </div>
      <% if (totals.taxCents > 0) { %>
        <div class="sum-row"><span>Estimated tax</span><span><%= money(totals.taxCents) %></span></div>
      <% } %>
      <div class="sum-row total"><span>Total</span><span><%= money(totals.totalCents) %></span></div>
      <% if (totals.shippingCents > 0 && freeShipThreshold > totals.subtotalCents) { %>
        <p class="ship-hint">Add <strong><%= money(freeShipThreshold - totals.subtotalCents) %></strong> more for free shipping 🚚</p>
      <% } %>
      <a href="/checkout" class="btn btn-primary btn-block btn-lg">Checkout securely →</a>
      <p class="secure-note">🔒 SSL-encrypted · USD</p>
    </aside>
  </div>
<% } %>

<%- include('../partials/footer') %>

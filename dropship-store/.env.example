# ---------------------------------------------------------------------------
# Dropship Store — environment configuration
# Copy this file to ".env" and adjust. All values are optional; sane
# defaults are used when a variable is omitted.
# ---------------------------------------------------------------------------

# Port the HTTP server listens on
PORT=3000

# Secret used to sign session cookies. CHANGE THIS to a long random string
# before deploying to production.
SESSION_SECRET=change-me-to-a-long-random-string

# Default admin account created on first run (seed). Change the password
# immediately after your first login, or set these before seeding.
ADMIN_EMAIL=admin@rewind.shop
ADMIN_PASSWORD=changeme123

# Set to "production" when hosting live (enables secure cookies behind HTTPS).
NODE_ENV=development

# ---------------------------------------------------------------------------
# Payments (optional). The store ships with a built-in demo checkout that
# records orders without charging a card. To take real payments, plug your
# Stripe keys in here and follow the integration notes in README.md.
# ---------------------------------------------------------------------------
# STRIPE_PUBLISHABLE_KEY=pk_test_xxx
# STRIPE_SECRET_KEY=sk_test_xxx
